{
  "info": {
    "_postman_id": "c53f64a8-644a-48d6-a619-54f0f8668c85",
    "name": "Document Intelligence Platform",
    "description": "Manual testing collection for the current document intelligence platform API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "01 - Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"health returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var payload = pm.response.json();",
                  "pm.test(\"health status is ok\", function () {",
                  "  pm.expect(payload.status).to.eql(\"ok\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Basic service health check."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "02 - Ingest Document (Create + Enqueue)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"ingest enqueue returns 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var payload = pm.response.json();",
                  "pm.collectionVariables.set(\"document_id\", payload.id);",
                  "",
                  "pm.test(\"document is enrichment pending\", function () {",
                  "  pm.expect(payload.status).to.eql(\"enrichment_pending\");",
                  "});",
                  "",
                  "pm.test(\"document id is captured\", function () {",
                  "  pm.expect(pm.collectionVariables.get(\"document_id\")).to.be.a(\"string\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_uri\": \"file:///docs/service-overview.md\",\n  \"title\": \"Service Overview\",\n  \"media_type\": \"text/markdown\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/documents/ingest",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "ingest"
              ]
            },
            "description": "Create a document record and enqueue downstream enrichment."
          },
          "response": []
        },
        {
          "name": "03 - Get Document (Enqueued)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"get enqueued document returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var payload = pm.response.json();",
                  "pm.test(\"response contains captured document id\", function () {",
                  "  pm.expect(payload.document.id).to.eql(pm.collectionVariables.get(\"document_id\"));",
                  "});",
                  "",
                  "pm.test(\"status remains enrichment_pending\", function () {",
                  "  pm.expect(payload.document.status).to.eql(\"enrichment_pending\");",
                  "});",
                  "",
                  "pm.test(\"chunks are empty before enrichment\", function () {",
                  "  pm.expect(payload.chunks.length).to.eql(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/documents/{{document_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "{{document_id}}"
              ]
            },
            "description": "Retrieve the enqueued document."
          },
          "response": []
        },
        {
          "name": "04 - Ingest Local Document (Sync End-to-End)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"local ingest returns 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var payload = pm.response.json();",
                  "pm.collectionVariables.set(\"local_document_id\", payload.id);",
                  "",
                  "pm.test(\"local ingest marks document ready\", function () {",
                  "  pm.expect(payload.status).to.eql(\"ready\");",
                  "});",
                  "",
                  "pm.test(\"local document id is captured\", function () {",
                  "  pm.expect(pm.collectionVariables.get(\"local_document_id\")).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.test(\"local ingest returns classification\", function () {",
                  "  pm.expect(payload.classification).to.be.an(\"object\");",
                  "  pm.expect(payload.classification.label).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.test(\"local ingest returns summary\", function () {",
                  "  pm.expect(payload.summary).to.be.an(\"object\");",
                  "  pm.expect(payload.summary.text).to.be.a(\"string\");",
                  "  pm.expect(payload.summary.text.length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_uri\": \"{{local_source_uri}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/documents/ingest/local",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "ingest",
                "local"
              ]
            },
            "description": "Synchronously parse a local file and persist document + chunks."
          },
          "response": []
        },
        {
          "name": "05 - Get Document (Locally Ingested)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"get local document returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var payload = pm.response.json();",
                  "pm.test(\"response contains local document id\", function () {",
                  "  pm.expect(payload.document.id).to.eql(pm.collectionVariables.get(\"local_document_id\"));",
                  "});",
                  "",
                  "pm.test(\"local document is ready\", function () {",
                  "  pm.expect(payload.document.status).to.eql(\"ready\");",
                  "});",
                  "",
                  "pm.test(\"local document has chunks\", function () {",
                  "  pm.expect(payload.chunks.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"local document has classification\", function () {",
                  "  pm.expect(payload.document.classification).to.be.an(\"object\");",
                  "  pm.expect(payload.document.classification.label).to.be.a(\"string\");",
                  "});",
                  "",
                  "pm.test(\"local document has summary\", function () {",
                  "  pm.expect(payload.document.summary).to.be.an(\"object\");",
                  "  pm.expect(payload.document.summary.text).to.be.a(\"string\");",
                  "  pm.expect(payload.document.summary.text.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"local chunks include embeddings\", function () {",
                  "  pm.expect(payload.chunks[0].embedding).to.be.an(\"array\");",
                  "  pm.expect(payload.chunks[0].embedding.length).to.be.above(0);",
                  "  pm.expect(typeof payload.chunks[0].embedding[0]).to.eql(\"number\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/documents/{{local_document_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "{{local_document_id}}"
              ]
            },
            "description": "Retrieve a synchronously ingested local document and verify chunk + enrichment persistence."
          },
          "response": []
        },
        {
          "name": "06 - Ingest Local Missing File (Expected 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"missing local source returns 404\", function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_uri\": \"{{missing_source_uri}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/documents/ingest/local",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "ingest",
                "local"
              ]
            },
            "description": "Negative test for missing local file handling."
          },
          "response": []
        },
        {
          "name": "07 - Ingest Local Unsupported Media Type (Expected 415)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"unsupported media type returns 415\", function () {",
                  "  pm.response.to.have.status(415);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_uri\": \"{{unsupported_source_uri}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/documents/ingest/local",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "ingest",
                "local"
              ]
            },
            "description": "Negative test for unsupported media type handling."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Ollama",
      "item": [
        {
          "name": "08 - Ollama Chat Smoke",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"ollama chat returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var payload = pm.response.json();",
                  "var content = payload.choices[0].message.content;",
                  "",
                  "pm.test(\"ollama chat returns non-empty content\", function () {",
                  "  pm.expect(content).to.be.a(\"string\");",
                  "  pm.expect(content.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"ollama chat response contains OK\", function () {",
                  "  pm.expect(content).to.include(\"OK\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{generation_model}}\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Reply with exactly: OK\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{ollama_base_url}}/chat/completions",
              "host": [
                "{{ollama_base_url}}"
              ],
              "path": [
                "chat",
                "completions"
              ]
            },
            "description": "Smoke-test the Ollama OpenAI-compatible chat endpoint with the configured generation model."
          },
          "response": []
        },
        {
          "name": "09 - Ollama Embedding Smoke",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"ollama embeddings returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var payload = pm.response.json();",
                  "var embedding = payload.data[0].embedding;",
                  "",
                  "pm.test(\"embedding vector is present\", function () {",
                  "  pm.expect(Array.isArray(embedding)).to.eql(true);",
                  "  pm.expect(embedding.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test(\"embedding values are numeric\", function () {",
                  "  pm.expect(typeof embedding[0]).to.eql(\"number\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model\": \"{{embedding_model}}\",\n  \"input\": \"Document intelligence platform\"\n}"
            },
            "url": {
              "raw": "{{ollama_base_url}}/embeddings",
              "host": [
                "{{ollama_base_url}}"
              ],
              "path": [
                "embeddings"
              ]
            },
            "description": "Smoke-test the Ollama OpenAI-compatible embeddings endpoint with the configured embedding model."
          },
          "response": []
        }
      ]
    }
  ],
